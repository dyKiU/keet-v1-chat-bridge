{
  "name": "keet-v1-chat-bridge",
  "version": "1.0.0",
  "description": "Bridge Keet rooms to OpenAI-compatible v1 chat completions",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "keet-v1-chat-bridge": "dist/cli.js",
    "qvac-hyperswarm-bridge": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "pear:qvac:start": "node scripts/pear-qvac-demo.mjs start",
    "pear:qvac:stop": "node scripts/pear-qvac-demo.mjs stop",
    "pear:qvac:status": "node scripts/pear-qvac-demo.mjs status",
    "pear:qvac:logs": "node scripts/pear-qvac-demo.mjs logs",
    "keet:agent:start": "node scripts/keet-live-agent-daemon.mjs start",
    "keet:agent:stop": "node scripts/keet-live-agent-daemon.mjs stop",
    "keet:agent:status": "node scripts/keet-live-agent-daemon.mjs status",
    "keet:agent:logs": "node scripts/keet-live-agent-daemon.mjs logs",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "b4a": "^1.8.0",
    "hypercore-id-encoding": "^1.3.0",
    "hyperswarm": "^4.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
